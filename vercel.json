{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/wallpaper.js": {
      "maxDuration": 15,
      "includeFiles": "./fonts/CormorantGaramond.ttf"
    }
  },
  "rewrites": [
    {
      "source": "/wallpaper.png",
      "destination": "/api/wallpaper.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
